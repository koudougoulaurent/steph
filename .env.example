# ============================================================
# VégéSuivi Pro — Variables d'environnement (EXEMPLE)
# Copiez ce fichier en .env pour le développement local
# NE JAMAIS committer .env dans git !
# Sur Render : renseignez ces variables dans Dashboard > Environment
# ============================================================

# ── Obligatoire ───────────────────────────────────────────────────
# Générez avec : python -c "import secrets; print(secrets.token_hex(32))"
# Sur Render : render.yaml le génère automatiquement (generateValue: true)
SECRET_KEY=changez-cette-valeur-obligatoirement-en-production

# ── Base de données Neon PostgreSQL ───────────────────────────────
# 1. Créez un projet sur https://neon.tech (gratuit)
# 2. Dashboard > Connection Details > copiez "Connection string"
# 3. Le format ressemble à :
#    postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/DBNAME?sslmode=require

# ── Environnement Flask ───────────────────────────────────────────
FLASK_CONFIG=production

# ── Optionnel ─────────────────────────────────────────────────────
# ORGANISATION=Direction Régionale de l'Environnement
# REGION=Votre Région
